{
  "name": "yuntu-pim",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm --filter backend dev\" \"pnpm --filter frontend dev\"",
    "build": "pnpm --filter shared build && pnpm --filter backend build && pnpm --filter frontend build",
    "db:generate": "pnpm --filter backend drizzle-kit generate",
    "db:migrate": "pnpm --filter backend drizzle-kit migrate",
    "db:studio": "pnpm --filter backend drizzle-kit studio"
  },
  "devDependencies": {
    "concurrently": "^8.0.0"
  },
  "pnpm": {
    "workspaces": ["packages/*"]
  }
}
